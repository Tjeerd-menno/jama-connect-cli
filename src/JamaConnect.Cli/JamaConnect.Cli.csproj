<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>jama-connect</AssemblyName>
    <RootNamespace>JamaConnect.Cli</RootNamespace>
    <OutputType>Exe</OutputType>
    <IsAotCompatible>true</IsAotCompatible>
    <PublishAot>true</PublishAot>
    <SelfContained>true</SelfContained>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\JamaConnect.Application\JamaConnect.Application.csproj" />
    <ProjectReference Include="..\JamaConnect.Infrastructure\JamaConnect.Infrastructure.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="System.CommandLine" />
    <PackageReference Include="Microsoft.Extensions.Hosting" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" />
  </ItemGroup>
  <ItemGroup>
    <None Remove="appsettings.json" />
    <EmbeddedResource Include="appsettings.json" LogicalName="JamaConnect.Cli.appsettings.json" />
  </ItemGroup>
</Project>
